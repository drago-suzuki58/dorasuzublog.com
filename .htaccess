Redirect 301 /game/12/for-first-steam-portal/ /games/for-first-steam-portal/
Redirect 301 /game/12/aperture-science-philosophy/ /games/aperture-science-philosophy/
Redirect 301 /programming/07/renpy-debug-ui/ /programming/renpy-debug-ui/
Redirect 301 /category/game/ /categories/games/
Redirect 301 /category/programming/ /categories/programming/
Redirect 301 /category/game/minecraft-mod/ /categories/games-minecraft/
Redirect 301 /minecraft-mod/02/mcmod-dragon4/ /games/minecraft/dragon4/
Redirect 301 /MOD-introduction/ /games/minecraft/mod-introduction/
