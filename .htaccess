# Generated by tools/generate-htaccess.js. Do not edit manually.
# Edit tools/redirects.json, then run npm run redirects:generate.

<IfModule mod_rewrite.c>
RewriteEngine On

RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Remove legacy AMP suffixes.
RewriteRule ^(.+)/amp/?$ /$1/ [R=301,L,NE]

# Send common scanner/probe URLs to the teapot page.
RewriteRule ^wp-login\.php$ /418/ [R=302,L,NC]
RewriteRule ^wp-admin/?$ /418/ [R=302,L,NC]
RewriteRule ^wp-admin/.*$ /418/ [R=302,L,NC]
RewriteRule ^xmlrpc\.php$ /418/ [R=302,L,NC]
RewriteRule ^wp-config\.php(?:\.(?:bak|backup|old|orig|save|swp|txt))?$ /418/ [R=302,L,NC]
RewriteRule ^wp-config-sample\.php$ /418/ [R=302,L,NC]
RewriteRule ^wp-json/wp/v2/users/?$ /418/ [R=302,L,NC]
RewriteRule ^wp-content/debug\.log$ /418/ [R=302,L,NC]
RewriteRule ^(?:wordpress|wp)/wp-login\.php$ /418/ [R=302,L,NC]
RewriteRule ^(?:wordpress|wp)/wp-admin(?:/.*)?$ /418/ [R=302,L,NC]
RewriteRule ^(?:wordpress|wp)/xmlrpc\.php$ /418/ [R=302,L,NC]
RewriteRule ^(?:phpmyadmin|phpMyAdmin|pma|myadmin|mysqladmin|dbadmin)(?:/.*)?$ /418/ [R=302,L,NC]
RewriteRule ^adminer(?:\.php|/.*)?$ /418/ [R=302,L,NC]
RewriteRule ^\.env(?:\.(?:local|production|development|bak|backup|save|old))?$ /418/ [R=302,L,NC]
RewriteRule ^\.git(?:/.*)?$ /418/ [R=302,L,NC]
RewriteRule ^\.svn(?:/.*)?$ /418/ [R=302,L,NC]
RewriteRule ^\.hg(?:/.*)?$ /418/ [R=302,L,NC]
RewriteRule ^\.DS_Store$ /418/ [R=302,L,NC]
RewriteRule ^\.aws/credentials$ /418/ [R=302,L,NC]
RewriteRule ^\.ssh/(?:id_rsa|config)$ /418/ [R=302,L,NC]
RewriteRule ^id_rsa$ /418/ [R=302,L,NC]
RewriteRule ^sftp-config\.json$ /418/ [R=302,L,NC]
RewriteRule ^ftp-config\.json$ /418/ [R=302,L,NC]
RewriteRule ^secrets?(?:\.(?:json|ya?ml|txt|env))?$ /418/ [R=302,L,NC]
RewriteRule ^config(?:\.(?:json|php|ini|ya?ml))?$ /418/ [R=302,L,NC]
RewriteRule ^(?:backup|backups|dump|db|database|site|www|public_html)(?:[-_.][A-Za-z0-9]+)?\.(?:zip|tar|tar\.gz|tgz|sql|gz|7z|rar)$ /418/ [R=302,L,NC]
RewriteRule ^composer\.(?:json|lock)$ /418/ [R=302,L,NC]
RewriteRule ^vendor/(?:autoload\.php|phpunit/phpunit/src/Util/PHP/eval-stdin\.php)$ /418/ [R=302,L,NC]
RewriteRule ^phpunit\.xml(?:\.dist)?$ /418/ [R=302,L,NC]
RewriteRule ^\.phpunit\.result\.cache$ /418/ [R=302,L,NC]
RewriteRule ^storage/logs/laravel\.log$ /418/ [R=302,L,NC]
RewriteRule ^artisan$ /418/ [R=302,L,NC]
RewriteRule ^actuator(?:/.*)?$ /418/ [R=302,L,NC]
RewriteRule ^(?:env|server-status|server-info)(?:/.*)?$ /418/ [R=302,L,NC]
RewriteRule ^(?:admin|administrator|manager|cpanel|webmail|owa)(?:/.*)?$ /418/ [R=302,L,NC]
RewriteRule ^administrator/index\.php$ /418/ [R=302,L,NC]
RewriteRule ^core/install\.php$ /418/ [R=302,L,NC]
RewriteRule ^(?:install|setup|phpinfo|info|login)\.php$ /418/ [R=302,L,NC]
RewriteRule ^(?:shell|cmd|wso|c99|r57|b374k|mini|eval-stdin|debug|test)\.php$ /418/ [R=302,L,NC]
RewriteRule ^\.github(?:/.*)?$ /418/ [R=302,L,NC]
RewriteRule ^\.gitlab-ci\.ya?ml$ /418/ [R=302,L,NC]
RewriteRule ^docker-compose\.ya?ml$ /418/ [R=302,L,NC]
RewriteRule ^Dockerfile$ /418/ [R=302,L,NC]

RewriteRule ^404/?$ - [R=404,L]
RewriteRule ^403/?$ - [F,L]
</IfModule>

ErrorDocument 404 /404/index.html
ErrorDocument 403 /403/index.html

Redirect 301 /sitemaps.xml /sitemap.xml
Redirect 301 /sitemaps-misc.xml /sitemap.xml
Redirect 301 /category-sitemap.xml /sitemap.xml
Redirect 301 /post-sitemap.xml /sitemap.xml
Redirect 301 /page-sitemap.xml /sitemap.xml
Redirect 301 /game/minecraft-mod/02/dragon4/ /games/minecraft/dragon4/
Redirect 301 /game/minecraft-mod/02/stacker/ /games/minecraft/stacker/
